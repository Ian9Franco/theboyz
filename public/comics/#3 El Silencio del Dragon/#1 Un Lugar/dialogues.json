        },
        {
          "focusY": 0.55,
          "dialogue": [
            {
              "text": "Este universo tiene cosas horribles, Sofi. Pero también tiene cosas buenas. No dejes que el ruido te tape lo que vale la pena conocer. Dale una oportunidad.",
              "speaker": "Ian",
              "style": "normal",
