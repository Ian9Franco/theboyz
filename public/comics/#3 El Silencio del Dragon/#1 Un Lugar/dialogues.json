    "9": {
      "panels": [
        {
          "focusY": 0.25,
          "dialogue": [
            {
              "text": "Tengo miedo, Ian. Este mundo es demasiado violento, hace mucho ruido.",
              "speaker": "Sofi",
              "style": "normal",
              "posX": 30,
              "posY": 20,
              "tail": "bottom-right"
            }
          ]
        },
        {
          "focusY": 0.55,
          "dialogue": [
            {
              "text": "Este universo tiene cosas horribles, Sofi. Pero también tiene cosas buenas. No dejes que el ruido te tape lo que vale la pena conocer. Dale una oportunidad.",
              "speaker": "Ian",
              "style": "normal",
              "posX": 65,
              "posY": 50,
              "tail": "top-left"
            }
          ]
        },
        {
          "focusY": 0.85,
          "dialogue": [
            {
              "text": "Me voy a recorrer el mundo sola. Necesito encontrar mi propio camino.",
              "speaker": "Sofi",
              "style": "normal",
              "posX": 30,
              "posY": 75,
              "tail": "bottom-right"
            },
            {
              "text": "Bueno... te llevo al aeropuerto. ¿A dónde querés ir?",
              "speaker": "Uandi",
              "style": "normal",
              "posX": 65,
              "posY": 80,
              "tail": "bottom-left"
            },
            {
              "text": "A cualquier parte. Lejos. Y ahora mismo.",
              "speaker": "Sofi",
              "style": "normal",
              "posX": 30,
              "posY": 88,
              "tail": "bottom-right"
            }
          ]
        }
      ]
