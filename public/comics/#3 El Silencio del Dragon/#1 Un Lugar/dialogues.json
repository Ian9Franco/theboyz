    "7": {
      "panels": [
        {
          "focusY": 0.2,
          "dialogue": [
            {
              "text": "Tranquila... acá vas a estar segura.",
              "speaker": "Ian",
              "style": "normal",
              "posX": 40,
              "posY": 15,
              "tail": "bottom-left"
            }
          ]
        },
        {
          "focusY": 0.5,
          "dialogue": [
            {
              "text": "¡Mierda! Perdón, se me resbaló...",
              "speaker": "Mati",
              "style": "normal",
