    "8": {
      "panels": [
        {
          "focusY": 0.15,
          "dialogue": [
            {
              "text": "Al menos la comida de este universo zafa.",
              "speaker": "Julián",
              "style": "normal",
              "posX": 60,
              "posY": 10,
              "tail": "bottom-left"
            }
          ]
        },
        {
          "focusY": 0.35,
          "dialogue": [
            {
              "text": "Che, necesita aire. Conozco una cabaña aislada en el mapa. Ahí no hay ruido. Dejame que la lleve a descansar.",
              "speaker": "Uandi",
              "style": "normal",
              "posX": 65,
              "posY": 30,
              "tail": "bottom-right"
            },
            {
              "text": "Gracias, Uandi. De verdad.",
              "speaker": "Sofi",
              "style": "normal",
              "posX": 30,
              "posY": 35,
              "tail": "bottom-left"
            }
          ]
        },
        {
          "focusY": 0.5,
          "dialogue": [
            {
              "text": "Tomá... es una laptop vieja. Para que... no sé, busques cosas de este lado.",
              "speaker": "Mati",
              "style": "whisper",
              "posX": 50,
              "posY": 50,
              "tail": "top-right"
            }
          ]
        },
        {
          "focusY": 0.65,
          "dialogue": [
            {
              "text": "Gracias...",
              "speaker": "Sofi",
              "style": "whisper",
              "posX": 40,
              "posY": 65,
              "tail": "bottom-left"
            }
          ]
        },
        {
          "focusY": 0.8,
          "dialogue": [
            {
              "text": "Todo es distinto... pero la miseria humana es la misma...",
              "speaker": "Sofi",
              "style": "thought",
              "posX": 50,
              "posY": 78,
              "tail": "bottom-left"
