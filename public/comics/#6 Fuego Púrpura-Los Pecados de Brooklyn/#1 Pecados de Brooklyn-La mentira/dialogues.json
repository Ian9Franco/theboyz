            { "text": ".. no puedo— mis ojos— no los controlo—", "size": "small", "posX": 100, "posY": 88, "tailX": 74, "tailY": 92, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
