    "1": {
      "panels": [
        {
          "focusY": 0.24,
          "dialogue": [
            { "text": "Qué raro... otra fluctuación en la red", "style": "thought", "size": "small", "posX": 48, "posY": 4, "tailX": 38, "tailY": 12, "tailWidth": 6, "tailCurvature": -36, "width": 125, "fontSize": 8, "borderRadius": 18 },
            { "text": "Cada vez que una de estas firmas de energía se apaga... siento que la presión en mi córnea aumenta. No tiene sentido.", "size": "small", "posX": 80, "posY": 30, "tailX": 36, "tailY": 24, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.46,
          "dialogue": [
            { "text": "tiki tiki tiki", "style": "sfx", "size": "small", "posX": 20, "posY": 36, "tailX": 48, "tailY": 52, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Tengo que borrar el historial y apagar esta máquina. Si el Comandante o Don Vanguard se enteran de que soy un mutante... no voy a salir de este edificio.", "size": "small", "posX": 4, "posY": 52, "tailX": 48, "tailY": 44, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "versiones de mati", "style": "caption", "size": "small", "posX": 102, "posY": 56, "tailX": 50, "tailY": 61, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "estas personas.. sera que..", "size": "small", "posX": 106, "posY": 62, "tailX": 76, "tailY": 62, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
