            { "text": "Le voy a decir a los demas, y vamos a resolver esto", "size": "small", "posX": 64, "posY": 44, "tailX": 42, "tailY": 54, "tailWidth": 6, "tailCurvature": -18, "width": 175, "fontSize": 9, "borderRadius": 18 }
