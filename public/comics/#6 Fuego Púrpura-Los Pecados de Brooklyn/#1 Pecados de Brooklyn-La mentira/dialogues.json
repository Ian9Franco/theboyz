        {
          "focusY": 0.42,
          "dialogue": [
            { "text": "Todavía respiraba. Eso era lo único que importaba.", "size": "small", "posX": 64, "posY": 34, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "tail": "none", "customBg": "#f5e642", "customColor": "#000000" },
            { "text": "Si Vanguard se entera... es el fin", "size": "small", "posX": 94, "posY": 58, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "tail": "none", "customBg": "#f5e642", "customColor": "#000000" }
