    "8": {
      "panels": [
        {
          "focusY": 0.14,
          "dialogue": [
            { "text": "Actualidad..", "style": "caption", "size": "small", "posX": 38, "posY": 2, "tailX": 48, "tailY": 8, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "customBg": "#f5e642", "customColor": "#000000" }
          ]
        },
        {
          "focusY": 0.58,
          "dialogue": [
            { "text": "Las runas bajaron a amarillo. Ya no estás en zona roja de sobrecarga cinético-batería", "size": "small", "posX": 46, "posY": 36, "tailX": 24, "tailY": 50, "tailWidth": 6, "tailCurvature": -22, "width": 230, "fontSize": 9, "borderRadius": 18 },
            { "text": "*(sin abrir los ojos, voz ronca)* \"Bien. Porque tengo un hambre de tres dimensiones.", "size": "small", "posX": 56, "posY": 44, "tailX": 42, "tailY": 58, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Julián, andá a comprar facturas antes de que se coma el sillón", "size": "small", "posX": 56, "posY": 56, "tailX": 36, "tailY": 60, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.64,
          "dialogue": [],
          "zoomRects": [
            { "x": 46, "y": 43, "w": 54, "h": 25 }
          ]
        },
        {
          "focusY": 0.84,
          "dialogue": [
            { "text": "Traje medialunas.", "size": "small", "posX": 30, "posY": 68, "tailX": 18, "tailY": 76, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "(abriendo un ojo)* Al fin. uno que aporta", "size": "small", "posX": 18, "posY": 100, "tailX": 36, "tailY": 88, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "mmh.. manchas de barro.. pero llovio de madrugada", "style": "thought", "size": "small", "posX": 106, "posY": 92, "tailX": 64, "tailY": 82, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ],
