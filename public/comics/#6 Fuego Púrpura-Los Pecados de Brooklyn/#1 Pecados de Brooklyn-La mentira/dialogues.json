    "2": {
      "panels": [
        {
          "focusY": 0.14,
          "dialogue": [
            { "text": "CLANG", "style": "sfx", "size": "small", "posX": 82, "posY": 28, "tailX": 50, "tailY": 29, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
