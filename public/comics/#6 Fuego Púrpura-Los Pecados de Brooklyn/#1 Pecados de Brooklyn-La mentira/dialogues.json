    "5": {
      "panels": [
        {
          "focusY": 0.2,
          "dialogue": [
            { "text": "Se detectó una intrusión cuántica no autorizada en el servidor del laboratorio. Protocolo de seguridad activo", "style": "electronic", "size": "small", "posX": 76, "posY": 16, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "tail": "left" }
          ]
        },
        {
          "focusY": 0.58,
          "dialogue": [
            { "text": "Que estan haciendo ustedes dos?", "size": "small", "posX": 62, "posY": 46, "tailX": 52, "tailY": 56, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
