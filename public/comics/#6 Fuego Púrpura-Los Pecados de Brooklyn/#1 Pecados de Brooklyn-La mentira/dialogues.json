          ],
          "hideUntilReached": false
        },
        {
          "focusY": 0.64,
          "dialogue": [
            { "text": "Mati... ¿qué es esto? Esas cosas... tienen tu cara", "size": "small", "posX": 4, "posY": 58, "tailX": 22, "tailY": 64, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Volvo, no debiste entrar. Es de uso restringido—", "size": "small", "posX": 94, "posY": 60, "tailX": 66, "tailY": 70, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Me dijiste que tu mutacion estaba bajo control, y estas exponiendonos a todos aca!", "size": "small", "posX": -8, "posY": 74, "tailX": 26, "tailY": 66, "tailWidth": 6, "tailCurvature": -50, "width": 200, "fontSize": 8, "borderRadius": 15 }
          ]
        },
        {
          "focusY": 0.92,
          "dialogue": [],
          "zoomRects": [
            { "x": 0, "y": 80, "w": 100, "h": 21 }
          ]
        }
      ]
    },
    "3": {
      "panels": [
        {
          "focusY": 0.16,
          "dialogue": [
            { "text": "¡Volvo, esperá! ¡No es lo que pensás!", "size": "small", "posX": 44, "posY": 26, "tailX": -20, "tailY": 24, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.48,
          "dialogue": [
            { "text": "Ocultar tu mutación a la agencia ya era una locura. ¡Pero estás rastreando firmas externas en su red! Si Vanguard detecta tu energía, va a mandar a R.E.G.U.L.A.R. y a toda la fuerza táctica a borrarnos del mapa.", "size": "small", "posX": 92, "posY": 40, "tailX": 60, "tailY": 48, "tailWidth": 6, "tailCurvature": -22, "width": 240, "fontSize": 8, "borderRadius": 23 },
            { "text": "¡No sé qué son esas firmas, Volvo! ¡Sólo intentaba rastrear mis picos de energía para apagarlos!", "size": "small", "posX": 6, "posY": 42, "tailX": 36, "tailY": 48, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.66,
          "dialogue": [
            { "text": "Hacete el pelotudo!\n¡Nos pusiste en su radar! Si descubren tu mutacion acá, ¡este lugar va a ser nuestra tumba!", "size": "small", "posX": 92, "posY": 66, "tailX": 62, "tailY": 68, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.9,
          "dialogue": [],
          "zoomRects": [
            { "x": 0, "y": 77, "w": 100, "h": 23 }
          ],
          "hideUntilReached": false
        }
      ]
    },
    "4": {
      "panels": [
        {
          "focusY": 0.18,
          "dialogue": [
            { "text": "No quiero hacer esto..", "size": "small", "posX": 88, "posY": 10, "tailX": 76, "tailY": 20, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
