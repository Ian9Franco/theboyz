    },
    "9": {
      "panels": [
        {
          "focusY": 0.18,
          "dialogue": [
            { "text": "¿Desde cuándo hacés eso con las cartas?", "size": "small", "posX": 88, "posY": 2, "tailX": 74, "tailY": 12, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Desde siempre, wachin. ¿Recién te das cuenta?", "size": "small", "posX": 66, "posY": 0, "tailX": 46, "tailY": 10, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Es una alteración electromagnética local. Estable mientras no haya carga emocional.", "size": "small", "posX": 102, "posY": 26, "tailX": 82, "tailY": 18, "tailWidth": 6, "tailCurvature": -22, "width": 150, "fontSize": 8, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.56,
          "dialogue": [
            { "text": "Con carga emocional solo por la wawi", "size": "small", "posX": 66, "posY": 46, "tailX": 52, "tailY": 52, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "¿Dónde está Sofi?", "size": "small", "posX": 26, "posY": 36, "tailX": 16, "tailY": 52, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "UANDI: Tokio\n", "size": "small", "posX": 14, "posY": 58, "tailX": -8, "tailY": 52, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.76,
          "dialogue": [
            { "text": "Y nosotros estamos acá, quebrados. La tele nueva sale una fortuna y hay que reconstruir el taller de Ian", "size": "small", "posX": 62, "posY": 62, "tailX": 42, "tailY": 84, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Igual, quédense tranquilos. Se me ocurrió una idea para conseguir la plata", "size": "small", "posX": 36, "posY": 62, "tailX": 32, "tailY": 74, "tailWidth": 32, "tailCurvature": 68, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "¿Qué idea?", "size": "small", "posX": -6, "posY": 74, "tailX": 6, "tailY": 80, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Un secreto comercial. Confíen en mí.", "speaker": "Julián", "size": "small", "posX": 92, "posY": 72, "tailX": 108, "tailY": 56, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        }
      ]
    }
